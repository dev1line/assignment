DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=teacher_student_db
PORT=3000
NODE_ENV=development

# Logging: trace | debug | info | warn | error | fatal | silent (defaults: info except test=silent)
LOG_LEVEL=

# true = log each SQL via Pino at debug (needs LOG_LEVEL=debug or trace). Omit/false = no SQL logs (recommended).
DB_SQL_LOG=

# Graceful shutdown: max ms to wait for in-flight HTTP requests before force exit (default 10000)
SHUTDOWN_TIMEOUT_MS=10000

# HTTP: CORS (comma-separated origins). Empty in production disables CORS; in development allows any origin (reflect).
# Example: http://localhost:5173,https://app.example.com
CORS_ORIGIN=http://localhost:5173

# Rate limit for /api (skipped when NODE_ENV=test)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# JSON body size (e.g. 100kb, 1mb)
REQUEST_BODY_LIMIT=100kb

# Reverse proxies in front of the app (e.g. AWS ALB = 1). 0 = do not trust X-Forwarded-* (local dev).
TRUST_PROXY_HOPS=0

# Docker Compose variables
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=teacher_student_db
MYSQL_PORT=3306
DOCKER_DB_HOST=db
DOCKER_NODE_ENV=production

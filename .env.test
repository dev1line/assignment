DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=teacher_student_test_db
PORT=3001
NODE_ENV=test

# Example: http://localhost:5173,https://app.example.com
CORS_ORIGIN=http://localhost:5173

# Rate limit for /api (skipped when NODE_ENV=test)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# JSON body size (e.g. 100kb, 1mb)
REQUEST_BODY_LIMIT=100kb

# Tests: no trusted proxy (default). Integration tests use direct connections.
TRUST_PROXY_HOPS=0

# Docker Compose variables
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=teacher_student_test_db
MYSQL_PORT=3307
DOCKER_DB_HOST=db
DOCKER_NODE_ENV=test